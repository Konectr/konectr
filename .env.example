# Supabase (required)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Notion Blog Integration (optional - for /blog)
NOTION_API_KEY=your-notion-api-key
NOTION_BLOG_DATABASE_ID=your-database-id

# Smart Download CTAs on /a/[code] and /r/[code] (optional)
# If unset, Download buttons fall back to https://konectr.app/#waitlist.
# Set these once the app is live on the public stores.
NEXT_PUBLIC_IOS_STORE_URL=https://apps.apple.com/app/id0000000000
NEXT_PUBLIC_ANDROID_STORE_URL=https://play.google.com/store/apps/details?id=com.konectr.konectrMobile

# TestFlight Public Link (optional)
# When set, the landing-page Hero swaps its badge to "🧪 TestFlight beta is live"
# and iPhone visitors get an "Open the beta on iPhone" CTA wired to this URL.
# Generated in App Store Connect → Konectr → TestFlight → External Testing → "Enable Public Link".
# Unset = unchanged behavior (badge shows "Launching ...", primary CTA goes to #waitlist).
NEXT_PUBLIC_TESTFLIGHT_URL=https://testflight.apple.com/join/your-code
